// Allocator
cc_binary {
    name: "vendor.qti.hardware.display.allocator-service",
    defaults: ["qtidisplay_alloc_defaults"],
    sanitize: {
        integer_overflow: true,
    },
    vendor: true,
    relative_install_path: "hw",
    header_libs: [
        "display_headers",
        "snapalloc_interface_headers",
        "common_interface_headers",
        "libimapper_stablec",
        "libimapper_providerutils",
    ],
    shared_libs: [
        "libbinder",
        "libbinder_ndk",
        "libhidlbase",
        "libgrallocutils",
        "libmapperutils",
        "libgralloccore",
        "libgralloctypes",
        "vendor.qti.hardware.display.mapper@3.0",
        "vendor.qti.hardware.display.mapper@4.0",
        "android.hardware.graphics.mapper@4.0",
        "android.hardware.graphics.mapper@3.0",
        "android.hardware.graphics.mapper@2.1",
        "vendor.qti.hardware.display.mapperextensions@1.0",
        "vendor.qti.hardware.display.mapperextensions@1.1",
        "libdmabufheap",
        "vendor.qti.hardware.display.mapperextensions@1.2",
        "vendor.qti.hardware.display.mapperextensions@1.3",
        "android.hardware.graphics.allocator-V2-ndk",
        "libjsoncpp",
        "libgralloc.qti",
        "libutilscallstack",
        "libvndksupport",
    ],
    static_libs: [
        "libaidlcommonsupport",
    ],
    cflags: [
        "-DLOG_TAG=\"qdgralloc\"",
        "-D__QTI_DISPLAY_GRALLOC__",
    ],
    srcs: [
        "QtiAllocatorAIDL.cpp",
        "service.cpp",
    ],
    init_rc: ["vendor.qti.hardware.display.allocator-service.rc"],
    vintf_fragments: ["vendor.qti.hardware.display.allocator-service.xml"],
}

