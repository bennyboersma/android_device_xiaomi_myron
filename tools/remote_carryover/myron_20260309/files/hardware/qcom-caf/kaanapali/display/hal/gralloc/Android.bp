//libgralloccore
cc_library_shared {
    name: "libgralloccore",
    defaults: [
        "qtidisplay_common_defaults",
        "qtidisplay_smmu_header_defaults",
        "qtidisplay_libubwcp_header_defaults"
    ],
    sanitize: {
        integer_overflow: true,
    },
    vendor: true,
    header_libs: [
        "display_headers",
        "qti_kernel_headers",
        "qti_display_kernel_headers",
        "device_kernel_headers",
        "libvmmem_headers",
    ],
    include_dirs: [
        "system/memory/libion/include",
        "system/memory/libion/kernel-headers",
    ],
    shared_libs: [
        "libdl",
        "libgrallocutils",
        "libgralloctypes",
        "libgralloc.qti",
        "libhidlbase",
        "libion",
        "libdmabufheap",
        "//vendor/xiaomi/sm8850-common:libvmmem",
        "android.hardware.graphics.mapper@2.1",
        "android.hardware.graphics.mapper@3.0",
        "android.hardware.graphics.mapper@4.0",
    ],
    cflags: [
        "-DLOG_TAG=\"qdgralloc\"",
        "-D__QTI_DISPLAY_GRALLOC__",
        "-Wno-sign-conversion",
        "-Wno-unused-parameter",
    ],
    srcs: [
        "gr_allocator.cpp",
        "gr_buf_mgr.cpp",
        "gr_dma_legacy_mgr.cpp",
        "gr_dma_mgr.cpp",
        "gr_alloc_interface.cpp",
    ],
}

//libgralloc
