//libgrallocutils
cc_library_shared {
    name: "libgrallocutils",
    defaults: [
        "qtidisplay_defaults_headless",
        "qtidisplay_common_defaults",
        "qtidisplay_libubwcp_header_defaults"
    ],
    vendor: true,
    sanitize: {
        integer_overflow: true,
    },
    header_libs: [
        "display_headers",
        "qti_kernel_headers",
        "qti_display_kernel_headers",
        "device_kernel_headers",
        "libubwcp_headers",
        "snapalloc_interface_headers",
        "common_interface_headers",
        "libimapper_stablec",
        "libimapper_providerutils",
    ],
    shared_libs: [
        "libdl",
        "libgralloctypes",
        "libhidlbase",
        "android.hardware.graphics.common@1.2",
        "android.hardware.graphics.mapper@2.0",
        "android.hardware.graphics.mapper@2.1",
        "android.hardware.graphics.mapper@3.0",
        "android.hardware.graphics.mapper@4.0",
        "libbinder_ndk",
        "libgralloc.qti",
        "android.hardware.graphics.allocator-V2-ndk",
    ],
    cflags: [
        "-DLOG_TAG=\"qdgralloc\"",
        "-D__QTI_DISPLAY_GRALLOC__",
        "-Wno-sign-conversion",
        "-Wno-unused-parameter",
        "-Wno-unused-variable",
    ],
    srcs: [
        "gr_utils.cpp",
        "gr_adreno_info.cpp",
        "gr_camera_info.cpp",
        "gr_ubwcp_utils.cpp",
        "gr_snap_helper.cpp",
        "gr_snap_debugger.cpp",
    ],
}

