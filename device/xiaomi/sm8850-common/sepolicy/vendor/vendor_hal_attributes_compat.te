#
# This file is a compatibility shim for missing Qualcomm vendor HAL attribute
# families while the tree still relies on fallback imported sepolicy sources.
# Keep it limited to attribute declarations. The canonical neverallow policy for
# these domains lives in the upstream Qualcomm policy sources that define the
# real HAL macros, and copying those neverallows here breaks on the bypass-style
# domains used by the fallback policy set.

type vendor_hal_atfwd_hwservice, hwservice_manager_type, protected_hwservice;
